<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>erensearch.com | Global Araştırma</title>
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        
        body {
            background:#06090f;
            color:#dce4f0;
            font-family:system-ui,-apple-system,sans-serif;
            min-height:100vh;
            position: relative;
            overflow-x: hidden;
        }

        /* ARKA PLAN - ana.png */
        body::before {
            content: "";
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            /* Başına eğik çizgi ekleyerek ana dizinden gelmesini garanti altına aldık */
            background-image: url('ana.png'); 
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            opacity: 0.35; 
            z-index: -1;
        }

        /* Ekranın daha okunabilir olması için koyu katman */
        body::after {
            content: "";
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.4);
            z-index: -1;
        }

        .c{max-width:900px;margin:0 auto;padding:30px 20px; position: relative; z-index: 1;}
        .header{text-align:center;margin-bottom:25px}
        .logo{font-size:36px;font-weight:900;background:linear-gradient(135deg,#60a5fa,#34d399);-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-1.5px}
        .motto{color:#dce4f0; font-size:16px; margin-top:10px; font-weight: 500; text-shadow: 0 2px 4px rgba(0,0,0,0.5)}
        
        /* Kartların Saydamlığı */
        .card{
            background:rgba(255,255,255,0.06);
            border:1px solid rgba(255,255,255,0.1);
            border-radius:24px;
            padding:25px;
            margin-bottom:20px;
            backdrop-filter: blur(15px); /* Daha güçlü buzlu cam efekti */
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .sr-container{display:flex; flex-direction:column; gap:12px; margin-bottom:15px}
        input{width:100%; padding:16px; border-radius:14px; border:1px solid rgba(255,255,255,0.1); background:rgba(0,0,0,0.5); color:#fff; font-size:17px; outline:none; transition:0.3s}
        input:focus{border-color:#60a5fa; background:rgba(0,0,0,0.7)}
        
        .btn{width:100%; padding:16px; border-radius:14px; border:none; background:linear-gradient(135deg,#3b82f6,#2563eb); color:#fff; font-weight:bold; font-size:16px; cursor:pointer; transition:0.2s; letter-spacing:1px}
        .btn:hover{transform:translateY(-2px); box-shadow:0 5px 15px rgba(59,130,246,0.4)}

        .lang-selector{display:grid; grid-template-columns:repeat(auto-fill, minmax(140px, 1fr)); gap:8px; margin-bottom:15px; display:none}
        .lang-opt{padding:10px; border-radius:10px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); color:#94a3b8; cursor:pointer; font-size:12px; display:flex; justify-content:space-between; align-items:center}
        .lang-opt.active{background:rgba(59,130,246,0.15); border-color:#3b82f6; color:#fff}
        .check-mark{display:none; color:#34d399; font-weight:bold}
        .lang-opt.active .check-mark{display:inline}
        
        .toggle-langs{font-size:13px; color:#60a5fa; cursor:pointer; background:none; border:none; margin-bottom:10px; text-decoration:underline}
        .hint{color:#3b82f6; font-size:13px; margin-top:15px; text-align: center; font-weight: 500}

        /* SONUÇ KARTLARI SAYDAMLIĞI */
        .res-card{
            background:rgba(0,0,0,0.5); 
            border:1px solid rgba(255,255,255,0.1);
            border-radius:18px;
            padding:18px 22px;
            margin-bottom:12px;
            display:flex;
            justify-content:space-between;
            align-items:center;
            animation:fadeIn 0.4s ease forwards;
            backdrop-filter: blur(10px);
        }

        .lang-meta{display:flex; align-items:center; gap:15px}
        .translated-val{font-size:18px; font-weight:600; color:#34d399}
        .go-link{padding:10px 18px; border-radius:10px; background:#3b82f6; color:#fff; text-decoration:none; font-size:13px; font-weight:bold; transition: 0.3s}
        .go-link:hover{background:#2563eb}
        
        @keyframes fadeIn{from{opacity:0; transform:translateY(15px)}to{opacity:1; transform:translateY(0)}}
    </style>
</head>
<body>

<div class="c">
    <div class="header">
        <div class="logo">erensearch.com</div>
        <p class="motto">Öğrenmek istediğiniz bilgiyi bütün evrende arayın.</p>
    </div>

    <div class="card">
        <div class="sr-container">
            <input type="text" id="q" placeholder="Araştırılacak kelime veya terimi yazın..." autocomplete="off">
            <button class="btn" id="searchBtn">EVRENDE ARA</button>
        </div>
        <button id="toggleBtn" class="toggle-langs">⚙️ Dil Tercihlerini Düzenle</button>
        <div id="selector" class="lang-selector"></div>
        <p class="hint">Küresel sonuçları yerel dilinizde okumak için tarayıcınızın otomatik çeviri özelliğini kullanmayı unutmayın.</p>
    </div>
    <div id="results"></div>
</div>

<script>
    const allLangs = [
        {c:"tr", n:"Türkçe", f:"🇹🇷", fixed:true}, {c:"en", n:"İngilizce", f:"🇬🇧", fixed:true},
        {c:"de", n:"Almanca", f:"🇩🇪", fixed:true}, {c:"fr", n:"Fransızca", f:"🇫🇷", fixed:true},
        {c:"ja", n:"Japonca", f:"🇯🇵"}, {c:"zh", n:"Çince", f:"🇨🇳"},
        {c:"ru", n:"Rusça", f:"🇷🇺"}, {c:"es", n:"İspanyolca", f:"🇪🇸"},
        {c:"it", n:"İtalyanca", f:"🇮🇹"}, {c:"ko", n:"Korece", f:"🇰🇷"},
        {c:"ar", n:"Arapça", f:"🇸🇦"}, {c:"pt", n:"Portekizce", f:"🇧🇷"},
        {c:"nl", n:"Hollandaca", f:"🇳🇱"}, {c:"sv", n:"İsveççe", f:"🇸🇪"},
        {c:"hi", n:"Hintçe", f:"🇮🇳"}, {c:"pl", n:"Lehçe", f:"🇵🇱"}
    ];

    let selected = ["tr", "en", "de", "fr", "ja", "ru"];

    const searchBtn = document.getElementById('searchBtn');
    const inputField = document.getElementById('q');
    const selectorDiv = document.getElementById('selector');
    const resultsDiv = document.getElementById('results');

    function renderSelector() {
        selectorDiv.innerHTML = allLangs.map(l => `
            <div class="lang-opt ${l.fixed ? 'active' : (selected.includes(l.c) ? 'active' : '')}" 
                 onclick="${l.fixed ? '' : `toggleLang('${l.c}')`}">
                <span>${l.f} ${l.n}</span>
                <span class="check-mark">✓</span>
            </div>
        `).join("");
    }

    window.toggleLang = function(code) {
        selected = selected.includes(code) ? selected.filter(c => c !== code) : [...selected, code];
        renderSelector();
    }

    document.getElementById('toggleBtn').onclick = () => {
        selectorDiv.style.display = (selectorDiv.style.display === "grid") ? "none" : "grid";
    };

    async function translateText(text, targetLang) {
        if(targetLang === "tr") return text;
        try {
            const url = `https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=${targetLang}&dt=t&q=${encodeURIComponent(text)}`;
            const res = await fetch(url);
            const data = await res.json();
            return data[0][0][0];
        } catch (e) { return text; }
    }

    async function go() {
        const q = inputField.value.trim();
        if(!q) return;
        searchBtn.disabled = true; searchBtn.innerText = "TARANIYOR...";
        resultsDiv.innerHTML = "<div style='text-align:center;padding:20px;color:#60a5fa'>🚀 Evren taranıyor...</div>";

        let html = "";
        for(let code of selected) {
            const lang = allLangs.find(x => x.c === code);
            const translated = await translateText(q, code);
            const searchUrl = `https://www.google.com/search?q=${encodeURIComponent(translated)}&hl=tr`;

            html += `
            <div class="res-card">
                <div class="lang-meta">
                    <span style="font-size:24px">${lang.f}</span>
                    <div>
                        <div style="font-size:10px; color:#60a5fa; font-weight:bold">${lang.n}</div>
                        <div class="translated-val">${translated}</div>
                    </div>
                </div>
                <a href="${searchUrl}" target="_blank" class="go-link">Sonuçları Gör →</a>
            </div>`;
        }
        resultsDiv.innerHTML = html;
        searchBtn.disabled = false; searchBtn.innerText = "EVRENDE ARA";
    }

    searchBtn.onclick = go;
    inputField.onkeypress = (e) => { if (e.key === 'Enter') go(); };
    renderSelector();
</script>
</body>
</html>
